# Telegram bot token (get it from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Your own numeric Telegram ID (get it from @userinfobot). This account is
# the permanent owner: always approved, can approve/reject/ban other admins,
# and can't be removed through bot commands.
OWNER_TELEGRAM_ID=YOUR_TELEGRAM_ID

# Shared secret sent as the X-API-Key header to the website's api/cats.php --
# must match BOT_API_KEY in the site's own .env. Generate with:
#   openssl rand -hex 24
BOT_API_KEY=

# Base URL of the sphynx-cattery-website API. Inside the homelab docker
# network this is the site container's service name; for local testing
# against `php -S localhost:8000` use that instead.
SITE_API_URL=http://sphynx-site/api/cats.php

# Ollama endpoint used to review a kitten's description (grammar/style) --
# this is the same instance other bots in the homelab talk to.
OLLAMA_URL=http://ollama:11434

# Chat model used for the description review. Small and fast is enough for
# a grammar/style pass.
CHAT_MODEL=qwen2.5:3b
